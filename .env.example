# Supabase (any ONE pair — build merges in vite.config.ts)
#
# Preferred (Vite default):
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
#
# Also supported (e.g. Vercel without VITE_ prefix):
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
#
# Next.js-style names work too:
# NEXT_PUBLIC_SUPABASE_URL=...
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
#
# Optional magic-link redirect (else = current page URL):
# VITE_AUTH_REDIRECT_URL=https://your-domain.com/#jackpot
# AUTH_REDIRECT_URL=...
#
# Jackpot staff PINs: no env vars here. Run migration 004, deploy Edge Function
# `jackpot-pin`, set secret JACKPOT_STAFF_USER_EMAIL in Supabase — see DEPLOY.md.
#
# Never commit .env. Never use service_role in the frontend.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
