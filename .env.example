# This Vite app only uses VITE_* (see src/lib/supabase.ts).
# Copy to .env and paste real values from Supabase → Settings → API.
#
# Required for: Connect 4 auth/leaderboard/chat, Jackpot owner login.
#
# Steps: docs/DATABASE_SETUP.md  |  Test: npm run check:db
#
# Optional: force magic-link return URL (must be listed in Supabase Redirect URLs).
# If unset, the app uses the current page URL (recommended).
# VITE_AUTH_REDIRECT_URL=https://your-domain.com/#jackpot

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
